{
  "deployment_targets": {
    "ios": {
      "swiftpm_platform": "iOS",
      "version": "13.0",
      "emit_to_package_manifest": true
    },
    "macos": {
      "swiftpm_platform": "macOS",
      "version": "10.15",
      "emit_to_package_manifest": true
    },
    "maccatalyst": {
      "swiftpm_platform": "macCatalyst",
      "version": "14.0",
      "emit_to_package_manifest": false
